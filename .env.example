# Postgres (Railway injects DATABASE_URL via the Postgres plugin in prod)
DATABASE_URL=postgres://user:pass@host:5432/db

# Better Auth (slice #3)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Stripe (slice #9) — test mode keys from dashboard.stripe.com
STRIPE_SECRET_KEY=
# Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Prod:  Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (slice #10)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# UploadThing (slice #6)
UPLOADTHING_TOKEN=

# Payment plans fake-mode fallback (slice #12)
PAYMENT_PLANS_FAKE_MODE=false
